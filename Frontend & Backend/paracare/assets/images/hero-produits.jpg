<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 400" width="500" height="400">
  <rect width="500" height="400" fill="#E8F4FD"/>
  <!-- Bottles arrangement -->
  <rect x="80" y="120" width="50" height="160" rx="8" fill="#2D9CDB" opacity="0.3"/>
  <rect x="80" y="100" width="50" height="30" rx="4" fill="#2D9CDB" opacity="0.5"/>
  <rect x="160" y="150" width="45" height="130" rx="8" fill="#27AE60" opacity="0.3"/>
  <rect x="160" y="130" width="45" height="30" rx="4" fill="#27AE60" opacity="0.5"/>
  <rect x="235" y="100" width="55" height="180" rx="10" fill="#f39c12" opacity="0.25"/>
  <rect x="235" y="80" width="55" height="30" rx="5" fill="#f39c12" opacity="0.4"/>
  <rect x="320" y="140" width="40" height="140" rx="8" fill="#e74c3c" opacity="0.2"/>
  <rect x="320" y="120" width="40" height="30" rx="4" fill="#e74c3c" opacity="0.35"/>
  <rect x="390" y="130" width="48" height="150" rx="8" fill="#9b59b6" opacity="0.25"/>
  <rect x="390" y="110" width="48" height="30" rx="4" fill="#9b59b6" opacity="0.4"/>
  <!-- Shelf -->
  <rect x="50" y="280" width="420" height="8" rx="2" fill="#ddd"/>
  <!-- Text -->
  <text x="250" y="340" font-family="Poppins, sans-serif" font-size="18" fill="#2D9CDB" text-anchor="middle" font-weight="600">ParaCare - Vos produits de soin</text>
</svg>
